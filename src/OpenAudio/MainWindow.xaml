<Window x:Class="OpenAudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenAudio"
        Width="780"
        Height="680"
        MinWidth="720"
        MinHeight="620"
        Background="#FFF5F5F4"
        Icon="Assets/app.ico"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="#FFE5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="ModernButtonBaseStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#FF2563EB" />
            <Setter Property="BorderBrush" Value="#FF2563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFE5E7EB" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FFE5E7EB" />
                                <Setter Property="Foreground" Value="#FF9CA3AF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModernButtonBaseStyle}">
            <Setter Property="Background" Value="#FF2563EB" />
            <Setter Property="BorderBrush" Value="#FF2563EB" />
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModernButtonBaseStyle}">
            <Setter Property="Foreground" Value="#FF111827" />
            <Setter Property="Background" Value="#FFF8FAFC" />
            <Setter Property="BorderBrush" Value="#FFD1D5DB" />
        </Style>

        <Style x:Key="DangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModernButtonBaseStyle}">
            <Setter Property="Background" Value="#FFDC2626" />
            <Setter Property="BorderBrush" Value="#FFDC2626" />
        </Style>

        <Style x:Key="MuteButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="13" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMicrophoneMuted}" Value="True">
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="Background" Value="#FFDC2626" />
                    <Setter Property="BorderBrush" Value="#FFDC2626" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource SectionCardStyle}">
                <StackPanel>
                    <DockPanel LastChildFill="True">
                        <Border Padding="12,6"
                                CornerRadius="14"
                                HorizontalAlignment="Left">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFFEE2E2" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsVbCableInstalled}" Value="True">
                                            <Setter Property="Background" Value="#FFD1FAE5" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <TextBlock Text="{Binding VbCableInstalledText}"
                                       FontWeight="SemiBold"
                                       Foreground="#FF111827" />
                        </Border>

                        <TextBlock Margin="16,2,0,0"
                                   VerticalAlignment="Top"
                                   Text="{Binding VbCableSummary}"
                                   Foreground="#FF6B7280"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </DockPanel>

                    <TextBlock Margin="0,14,0,0"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="{Binding GameMicrophoneInstruction}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1">
                <Border Style="{StaticResource SectionCardStyle}" Visibility="{Binding SetupVisibility}">
                    <StackPanel>
                        <TextBlock Text="VB-Cable setup required"
                                   FontSize="20"
                                   FontWeight="SemiBold" />

                        <TextBlock Margin="0,10,0,0"
                                   Text="{Binding SetupBodyText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Margin="0,16,0,0"
                                   FontWeight="SemiBold"
                                   Text="Install steps" />

                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding InstallStepsText}"
                                   TextWrapping="Wrap" />

                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Official download"
                                    Command="{Binding OpenDownloadCommand}"
                                    Margin="0,0,12,0" />
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Content="I installed it, recheck"
                                    Command="{Binding RecheckCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}" Visibility="{Binding MainVisibility}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Style="{StaticResource LabelStyle}" Text="Music source" />

                        <ComboBox Grid.Row="1"
                                  ItemsSource="{Binding ApplicationSources}"
                                  SelectedItem="{Binding SelectedApplicationSource}"
                                  DisplayMemberPath="DisplayName"
                                  IsEnabled="{Binding CanEditDeviceSelection}"
                                  MinHeight="34"
                                  Margin="0,0,0,10" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,0,0,14"
                                   Foreground="#FF6B7280"
                                   Text="{Binding MusicSourceHelperText}"
                                   TextWrapping="Wrap" />

                        <CheckBox Grid.Row="3"
                                  Content="Include microphone"
                                  IsChecked="{Binding IncludeMicrophone}"
                                  IsEnabled="{Binding CanEditDeviceSelection}"
                                  Margin="0,0,0,12" />

                        <TextBlock Grid.Row="4" Style="{StaticResource LabelStyle}" Text="Microphone" />
                        <ComboBox Grid.Row="5"
                                  ItemsSource="{Binding Microphones}"
                                  SelectedItem="{Binding SelectedMicrophone}"
                                  DisplayMemberPath="DisplayName"
                                  IsEnabled="{Binding IsMicrophoneSelectionEnabled}"
                                  MinHeight="34"
                                  Margin="0,0,0,14" />

                        <Grid Grid.Row="6" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource LabelStyle}"
                                       Text="Music volume" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="{Binding MusicVolumeText}" />
                        </Grid>

                        <Slider Grid.Row="7"
                                Minimum="0"
                                Maximum="100"
                                TickFrequency="5"
                                Value="{Binding MusicVolume}"
                                Margin="0,0,0,14" />

                        <Grid Grid.Row="8" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource LabelStyle}"
                                       Text="Mic volume" />
                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"
                                       FontWeight="SemiBold"
                                       Text="{Binding MicrophoneVolumeText}" />
                            <Button Grid.Column="2"
                                    Style="{StaticResource MuteButtonStyle}"
                                    Content="{Binding MicrophoneMuteButtonText}"
                                    Command="{Binding ToggleMicrophoneMuteCommand}"
                                    IsEnabled="{Binding IsMicrophoneMuteEnabled}" />
                        </Grid>

                        <Slider Grid.Row="9"
                                Minimum="0"
                                Maximum="100"
                                TickFrequency="5"
                                Value="{Binding MicrophoneVolume}"
                                IsEnabled="{Binding IsMicrophoneVolumeEnabled}"
                                Margin="0,0,0,6" />
                    </Grid>
                </Border>
            </StackPanel>

            <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="Start"
                            Command="{Binding StartCommand}"
                            Margin="0,0,12,0" />

                    <Button Grid.Column="1"
                            Style="{StaticResource DangerButtonStyle}"
                            Content="Stop"
                            Command="{Binding StopCommand}" />

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Status" FontWeight="SemiBold" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding StatusText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>

